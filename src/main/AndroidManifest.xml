<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Android 13+ runtime notification permission. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application>
        <!-- The SDK's FCM service. Apps that already have their own
             FirebaseMessagingService should instead forward to
             EngagePop.handleRemoteMessage / EngagePop.handleNewToken. -->
        <service
            android:name="com.engagepop.EngagePopMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>

</manifest>
